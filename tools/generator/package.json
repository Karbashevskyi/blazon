{
  "name": "@blazon/generator",
  "version": "0.1.0",
  "private": true,
  "description": "CLI tool that converts SVG files into Blazon registry entries",
  "repository": {
    "type": "git",
    "url": "https://github.com/Karbashevskyi/blazon.git"
  },
  "type": "module",
  "bin": {
    "blazon-generate": "./dist/bin/generate.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src bin",
    "generate": "tsx bin/generate.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@blazon/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
