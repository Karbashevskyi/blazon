{
  "name": "@blazon/core",
  "version": "0.1.0",
  "description": "Framework-agnostic Blazon heraldry registry core",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./validation": {
      "import": "./dist/domain/validation.js",
      "types": "./dist/domain/validation.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@blazon/types": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
