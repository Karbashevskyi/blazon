{
  "name": "@blazon/country-poland",
  "version": "0.1.0",
  "description": "Polish city coats of arms — tree-shakeable, typed data package for the Blazon registry",
  "repository": {
    "type": "git",
    "url": "https://github.com/Karbashevskyi/blazon.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@blazon/types": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "catalog:",
    "typescript": "catalog:"
  },
  "keywords": [
    "blazon",
    "heraldry",
    "coat-of-arms",
    "poland",
    "polish"
  ],
  "license": "MIT"
}
