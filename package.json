{
  "name": "blazon",
  "version": "0.1.0",
  "description": "Open-source heraldry registry with universal core and framework adapters",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,html,css}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,html,css}\"",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "generate": "turbo generate",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build && changeset publish",
    "clean": "turbo clean && rimraf node_modules"
  },
  "keywords": [
    "heraldry",
    "coat-of-arms",
    "blazon",
    "registry",
    "angular"
  ],
  "author": "Blazon Contributors",
  "license": "MIT",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
